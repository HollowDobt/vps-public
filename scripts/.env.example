# VPS 脚本配置示例。
#
# 使用方法：
#   cp scripts/.env.example scripts/.env
#   chmod 600 scripts/.env
#   vim scripts/.env
#
# 这个文件按当前自用集群偏好给出默认值。一般只需要修改节点名、
# SSH 公钥、Headscale 接入密钥、k3s node token、GitHub token、
# Cloudflare token 和备份目标。
#
# 脚本会优先读取同目录 .env。首次部署时会按需复制到
# /etc/hlwdot/vps.env，供后续脚本和 systemd 定时任务读取。

# 当前节点身份。留空时脚本会尽量使用系统 hostname。
BOOTSTRAP_HOSTNAME=
HEADSCALE_CLIENT_HOSTNAME=
K3S_NODE_NAME=

# 必填密钥按场景填写。
# - 首次初始化：优先使用 /root/.ssh/authorized_keys，也可以直接填 BOOTSTRAP_AUTHORIZED_KEYS。
# - 接入 hollow-net：先在 Headscale 主节点菜单里签发，再填 HEADSCALE_AUTHKEY。
# - 接入 k3s worker：先在 k3s 主节点菜单里查看 token，再填 K3S_AGENT_TOKEN。
# - 部署 Flux：默认使用 SSH deploy key，不需要在服务器保存 GitHub token。
# - 自动配置 Cloudflare DNS：填写 Cloudflare API token。
BOOTSTRAP_AUTHORIZED_KEYS=
HEADSCALE_AUTHKEY=
K3S_AGENT_TOKEN=
GITHUB_TOKEN=
CLOUDFLARE_API_TOKEN=

# 全局偏好。
VPS_PERSIST_ENV=1
HOLLOW_NET_IFACE=hollow-net
HOLLOW_NET_UFW_ALLOW=1

# Debian 13 基础初始化。
BOOTSTRAP_USER=hollow
BOOTSTRAP_TIMEZONE=Asia/Shanghai
BOOTSTRAP_LOCALE=en_US.UTF-8
BOOTSTRAP_EXTRA_LOCALES=zh_CN.UTF-8
BOOTSTRAP_SSH_PORT=22
BOOTSTRAP_SSH_LOCKDOWN=auto
BOOTSTRAP_SUDO_NOPASSWD=auto
BOOTSTRAP_ENABLE_UFW=1
BOOTSTRAP_ENABLE_FAIL2BAN=1
BOOTSTRAP_ENABLE_UNATTENDED_UPGRADES=1
BOOTSTRAP_FULL_UPGRADE=1
BOOTSTRAP_ENABLE_BBR=1
BOOTSTRAP_AUTHORIZED_KEYS_SOURCE=/root/.ssh/authorized_keys
BOOTSTRAP_USER_PASSWORD_HASH=
BOOTSTRAP_USER_PASSWORD=
BOOTSTRAP_ENABLE_SWAP=1
BOOTSTRAP_SWAPFILE=/swapfile
BOOTSTRAP_SWAP_SIZE=auto

# Headscale 服务端。
HEADSCALE_VERSION=stable
HEADSCALE_SERVER_HOSTNAME=headscale.hlwdot.com
HEADSCALE_SERVER_URL=https://headscale.hlwdot.com
HEADSCALE_LISTEN_ADDR=127.0.0.1:8080
HEADSCALE_METRICS_LISTEN_ADDR=127.0.0.1:9090
HEADSCALE_GRPC_LISTEN_ADDR=127.0.0.1:50443
HEADSCALE_DNS_BASE_DOMAIN=net.hlwdot.com
HEADSCALE_USER=hollow
HEADSCALE_CREATE_PREAUTHKEY=0
HEADSCALE_PREAUTH_REUSABLE=0
HEADSCALE_PREAUTH_EXPIRATION=24h
HEADSCALE_CONFIG_APPEND_FILE=
HEADSCALE_UFW_ALLOW=0
HEADSCALE_UFW_PORTS=8080/tcp
HEADSCALE_ENABLE_CADDY=1
HEADSCALE_CADDYFILE=/etc/caddy/Caddyfile
HEADSCALE_CADDY_EMAIL=
HEADSCALE_CADDY_UFW_ALLOW=1
HEADSCALE_CADDY_VERIFY=1
HEADSCALE_CADDY_VERIFY_TIMEOUT_SEC=120
HEADSCALE_CADDY_REPAIR_CERT_CACHE=1
HEADSCALE_EXCLUSIVE_PUBLIC_PORTS=1
HEADSCALE_DISABLE_K3S_CONFLICTS=1

# Headscale 主节点组合部署。基础初始化固定由菜单中的初始化项执行。
HEADSCALE_MAIN_JOIN_SELF=1

# Headscale 客户端。
HEADSCALE_CLIENT_IP=
HEADSCALE_ACCEPT_DNS=true
HEADSCALE_ADVERTISE_ROUTES=
HEADSCALE_ADVERTISE_EXIT_NODE=0
HEADSCALE_ENABLE_TS_SSH=0
HEADSCALE_RESET=0
HEADSCALE_EXTRA_UP_ARGS=
HEADSCALE_ENDPOINT_CHECK=1
HEADSCALE_ENDPOINT_CHECK_TIMEOUT_SEC=15
HEADSCALE_CLIENT_UP_TIMEOUT_SEC=120

# Alpine 小鸡 hollow-net 接入。
# 这类节点只接入内网或承担入站/出站分流，不部署 k3s。
ALPINE_TAILSCALE_INSTALL_SOURCE=auto
ALPINE_TAILSCALE_MIN_VERSION=1.74.0
ALPINE_TAILSCALE_STATIC_URL=auto
ALPINE_ENABLE_COMMUNITY_REPO=1
ALPINE_COMMUNITY_REPO_URL=auto
ALPINE_ENABLE_FORWARDING=auto
HOLLOW_OPENRC_SERVICE=hollow-tailscaled
ALPINE_SPLIT_DIRECTION=none
ALPINE_SPLIT_ROUTE_CIDRS=
ALPINE_SPLIT_OUTBOUND_PROXY_PORTS=
ALPINE_SPLIT_INBOUND_FORWARDS=
ALPINE_PUBLIC_IFACE=auto
ALPINE_ALLOW_INTERACTIVE_LOGIN=0
ALPINE_KILL_STALE_TAILSCALE_UP=1
ALPINE_TAILSCALE_UP_TIMEOUT_SEC=120

# NodeGet hollow-net 探针页。
# 仅用于 Alpine NAT LXC 小鸡。NodeGet Server/Caddy 只监听 127.0.0.1，
# Agent 上报入口只绑定 hollow-net IPv4；对外访问只走 Cloudflare Tunnel，
# 不创建公网 A 记录直连 VPS。
# NODEGET_VISITOR_TOKEN 请填 NodeGet 只读 Visitor token，不能填 Super Token；
# 首次安装时可先留空，脚本会初始化主控和隧道，之后创建 Visitor token 再重跑。
# NODEGET_CLOUDFLARED_TOKEN 是 Cloudflare Zero Trust 里该 Tunnel 的运行 token，
# 权限只够运行这条隧道。
# NODEGET_DNS_CONFIG_TOKEN 只用于幂等配置 healthy-page tunnel public hostname
# 和该 hostname 的 proxied CNAME；请限制到对应 Account 的 Cloudflare Tunnel Edit
# 和对应 Zone 的 DNS Edit，不要给全局 key。
NODEGET_VERSION=v0.1.4
NODEGET_RELEASE_REPO=GenshinMinecraft/NodeGet
NODEGET_STATUSSHOW_REPO=NodeSeekDev/NodeGet-StatusShow
NODEGET_STATUSSHOW_REF=276786c0853dbdbbdbfaf529d6b02dad501d689f
NODEGET_STATUS_HOSTNAME=nodeget.hlwdot.com
NODEGET_STATUS_SITE_NAME=Hollow Net Status
NODEGET_STATUS_FOOTER=Powered by NodeGet
NODEGET_STATUS_LOGO=
NODEGET_VISITOR_TOKEN=
NODEGET_SERVER_NAME=hollow-net
NODEGET_SERVER_UUID=auto_gen
NODEGET_SERVER_LISTEN=127.0.0.1:2211
NODEGET_STATUS_LISTEN=127.0.0.1:8221
NODEGET_DATABASE_URL='sqlite:///var/lib/nodeget-server/nodeget-server.db?mode=rwc'
NODEGET_JSONRPC_MAX_CONNECTIONS=80
NODEGET_AGENT_INGRESS_ENABLE=1
NODEGET_AGENT_LISTEN_ADDR=auto
NODEGET_AGENT_LISTEN_PORT=2211
NODEGET_CLOUDFLARED_ENABLE=1
NODEGET_CLOUDFLARED_VERSION=2026.3.0
NODEGET_CLOUDFLARED_TOKEN=
NODEGET_TUNNEL_CONFIG_ENABLE=auto
NODEGET_TUNNEL_NAME=healthy-page
NODEGET_DNS_CONFIG_TOKEN=
NODEGET_CLOUDFLARE_ACCOUNT_ID=
NODEGET_CLOUDFLARE_ZONE=hlwdot.com
NODEGET_CLOUDFLARE_ZONE_ID=
NODEGET_HOLLOW_SYNC_INTERVAL_SEC=30
NODEGET_HOLLOW_DNS_SUFFIXES=net.hlwdot.com,hlwdot.com
NODEGET_HOLLOW_NAME_ALIASES=center:CNETER
NODEGET_HOLLOW_PUBLISH_IP=0

# k3s 主节点。
K3S_VERSION=
K3S_TOKEN=
K3S_CLUSTER_INIT=1
K3S_NODE_IP=
K3S_ADVERTISE_ADDRESS=
K3S_FLANNEL_IFACE=hollow-net
K3S_CLUSTER_CIDR=10.42.0.0/16
K3S_SERVICE_CIDR=10.43.0.0/16
K3S_DISABLE_COMPONENTS=
K3S_KUBECONFIG_MODE=0600
K3S_ETCD_SNAPSHOT_SCHEDULE='0 */12 * * *'
K3S_ETCD_SNAPSHOT_RETENTION=5
K3S_ETCD_SNAPSHOT_COMPRESS=1
K3S_SERVER_EXTRA_ARGS=
K3S_UFW_ALLOW=1
K3S_UFW_INTERFACE=hollow-net
K3S_UFW_ALLOW_ETCD=0
K3S_API_PORT=6443
K3S_TAILNET_BOOT_WAIT_SEC=120

# k3s 子节点。
# 默认接入当前中心节点 server999.center。更换中心节点时改这里。
K3S_SERVER_HOSTNAME=
K3S_SERVER_URL=https://100.64.0.2:6443
K3S_AGENT_EXTRA_ARGS=

# k3s 组合部署。普通主/子节点部署只检查依赖状态，不自动执行依赖脚本。
K3S_MAIN_ENABLE_FLUX=1
K3S_WORKER_FULL_RUN_BOOTSTRAP=1
K3S_WORKER_FULL_RUN_CHECK=1
K3S_WORKER_FULL_RUN_HEADSCALE=1

# Flux GitOps。
FLUX_GITHUB_HOSTNAME=github.com
FLUX_GITHUB_OWNER=HollowDobt
FLUX_GITHUB_REPO=vps-gitops
FLUX_GITHUB_BRANCH=main
FLUX_GITHUB_PRIVATE=1
FLUX_GITHUB_PERSONAL=1
FLUX_GIT_AUTH=ssh
FLUX_GIT_URL=
FLUX_GIT_SSH_KEY_FILE=/etc/fluxcd/github-deploy.key
# 留空时使用 K3S_NODE_NAME / HEADSCALE_CLIENT_HOSTNAME 作为集群名。
FLUX_CLUSTER_NAME=
FLUX_GITHUB_PATH=
FLUX_COMPONENTS_EXTRA=
FLUX_REPO_SCAFFOLD=1
FLUX_AGE_KEY_FILE=/etc/fluxcd/sops-age.agekey
FLUX_AGE_PUBLIC_KEY=
FLUX_INTERVAL=10m0s
FLUX_RETRY_INTERVAL=1m0s
FLUX_TIMEOUT=5m0s
FLUX_FORGET_GITHUB_TOKEN=1

# Cloudflare DNS。
# Headscale 记录不要开启 Cloudflare 代理。
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ZONE=hlwdot.com
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DNS_TARGET_IPV4=auto
CLOUDFLARE_DNS_PROXIED=0
CLOUDFLARE_DNS_TTL=120
CLOUDFLARE_HEADSCALE_DNS=1
CLOUDFLARE_K3S_DNS_TARGET=tailnet
CLOUDFLARE_K3S_DNS_NAMES=

# 主节点备份。默认关闭；启用后必须配置 GPG 接收方和上传目标。
BACKUP_ENABLE=0
BACKUP_GPG_EMAILS=
BACKUP_GPG_RECIPIENTS=
BACKUP_GPG_PUBLIC_KEY_FILE=
BACKUP_GPG_PUBLIC_KEY_URL=
BACKUP_LOCAL_DIR=/var/backups/hlwdot
BACKUP_KEEP_LOCAL=7
BACKUP_RCLONE_DESTS=
BACKUP_GIT_REPOS=
BACKUP_GIT_BRANCH=main
BACKUP_GIT_SUBDIR=vps-backups
BACKUP_ON_CALENDAR='*-*-* 03:30:00'
BACKUP_RANDOMIZED_DELAY_SEC=15m
