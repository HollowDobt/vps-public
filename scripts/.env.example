# VPS 脚本配置示例。
#
# 使用方法：
#   cp scripts/.env.example scripts/.env
#   chmod 600 scripts/.env
#   vim scripts/.env
#
# 配置范围：
#   - 基础初始化需要节点名和 SSH 公钥来源。
#   - hollow-net 接入需要 Headscale 服务端地址；自动接入需要 HEADSCALE_AUTHKEY。
#   - k3s worker 接入需要 K3S_SERVER_URL，以及 K3S_AGENT_TOKEN 或 K3S_TOKEN。
#   - Headscale/k3s/Flux/NodeGet/备份配置只被对应脚本读取。
#
# 脚本会优先读取同目录 .env。首次部署时会复制到
# /etc/hlwdot/vps.env，供后续脚本和 systemd 定时任务读取。

# 按脚本/菜单项填写速查。下列为前置条件、必填项和条件必填项。
#
# 重装为 Debian 13：dd2debian13.sh
#   这个外部重装脚本不依赖本 .env；菜单会再次要求确认。
#
# Debian 13 基础初始化：debian13-bootstrap.sh
#   必填：VPS_NODE_NAME
#   SSH 登录公钥来源必须有其一：
#     BOOTSTRAP_AUTHORIZED_KEYS
#     BOOTSTRAP_AUTHORIZED_KEYS_SOURCE 指向的文件中已有公钥，默认 /root/.ssh/authorized_keys
#     root、BOOTSTRAP_USER、SUDO_USER 或现有 UID>=1000 用户已有 authorized_keys
#     forced-command key 不作为登录 key
#   非必填：BOOTSTRAP_SSH_PORT、BOOTSTRAP_SSH_LOCKDOWN、BOOTSTRAP_SWAP_SIZE
#
# Debian 13 初始化校验：debian13-bootstrap-check.sh
#   必填：VPS_NODE_NAME。
#   条件必填：覆盖校验目标时填写 VERIFY_* 或对应 BOOTSTRAP_* 变量。
#
# Alpine 基础初始化：alpine-bootstrap.sh
#   必填：VPS_NODE_NAME
#   SSH 登录公钥来源必须有其一：
#     BOOTSTRAP_AUTHORIZED_KEYS
#     BOOTSTRAP_AUTHORIZED_KEYS_SOURCE 指向的文件中已有公钥，默认 /root/.ssh/authorized_keys
#     root、BOOTSTRAP_USER、SUDO_USER 或现有 UID>=1000 用户已有 authorized_keys
#     forced-command key 不作为登录 key
#   非必填：BOOTSTRAP_SSH_PORT、BOOTSTRAP_SSH_LOCKDOWN、BOOTSTRAP_SWAP_SIZE
#   非必填：HOLLOW_NET_IFACE；BOOTSTRAP_ENABLE_UFW=1 时该网卡入站会被放行。
#   非必填：ALPINE_LXC_MODE；默认 1，按 Alpine LXC 执行，不在容器内创建 swapfile/zram。
#   非必填：ALPINE_COMMUNITY_REPO_URL；auto 时按 main 仓库推导，推导失败时使用官方 CDN。
#
# 部署 Headscale 主节点：headscale-main-node.sh
#   必填：VPS_NODE_NAME
#   必填/需能推导：HEADSCALE_SERVER_URL，或 HEADSCALE_SERVER_HOSTNAME/CLOUDFLARE_ZONE
#   条件必填：自动写 DNS 时填写 CLOUDFLARE_API_TOKEN，或 CLOUDFLARE_EMAIL + CLOUDFLARE_API_KEY
#   HEADSCALE_MAIN_JOIN_SELF=1 时脚本会自动签发 HEADSCALE_AUTHKEY 并把本机接入 hollow-net。
#
# 只部署 Headscale 服务端：headscale-server.sh
#   必填/需能推导：HEADSCALE_SERVER_URL，或 HEADSCALE_SERVER_HOSTNAME/CLOUDFLARE_ZONE
#   非必填：HEADSCALE_DNS_BASE_DOMAIN、HEADSCALE_ENABLE_CADDY、HEADSCALE_USER
#   条件必填：自动 DNS 同上需要 Cloudflare token；备份同下方 BACKUP_*。
#
# 签发 Headscale 接入密钥：headscale-authkey.sh
#   前置条件：必须在 Headscale 服务端机器运行。
#   无必填项。
#   非必填：HEADSCALE_USER、HEADSCALE_PREAUTH_REUSABLE、HEADSCALE_PREAUTH_EXPIRATION。
#
# 接入 Headscale 网络：headscale-client.sh
#   必填：VPS_NODE_NAME
#   必填/需能推导：HEADSCALE_SERVER_URL，或 HEADSCALE_SERVER_HOSTNAME/CLOUDFLARE_ZONE
#   条件必填：自动接入时填写 HEADSCALE_AUTHKEY；无 HEADSCALE_AUTHKEY 时进入手动网页登录流程。
#   非必填：HEADSCALE_ACCEPT_DNS、HEADSCALE_ADVERTISE_ROUTES、HEADSCALE_ADVERTISE_EXIT_NODE、HEADSCALE_RESET
#
# Alpine 节点接入 hollow-net：alpine-hollow-client.sh
#   必填：VPS_NODE_NAME
#   必填/需能推导：HEADSCALE_SERVER_URL
#   条件必填：自动接入时填写 HEADSCALE_AUTHKEY；手动网页登录需 ALPINE_ALLOW_INTERACTIVE_LOGIN=1。
#   条件必填：启用分流时填写 ALPINE_SPLIT_DIRECTION 以及对应的
#     ALPINE_SPLIT_ROUTE_CIDRS、
#     ALPINE_SPLIT_OUTBOUND_PROXY_PORTS、ALPINE_SPLIT_INBOUND_FORWARDS。
#
# 部署 k3s 主节点：k3s-main-node.sh / k3s-server.sh
#   前置条件：当前节点已经接入 hollow-net。
#   必填：VPS_NODE_NAME
#   自动生成/读取：K3S_TOKEN。
#   条件必填：自动写 k3s DNS 时填写 CLOUDFLARE_K3S_DNS_NAMES 和 Cloudflare token。
#   条件必填：K3S_MAIN_ENABLE_FLUX=1 时填写下方 FLUX_*。
#
# 部署 k3s 子节点：k3s-worker-node.sh / k3s-agent.sh
#   前置条件：当前节点已经接入 hollow-net。
#   必填：VPS_NODE_NAME
#   必填：K3S_SERVER_URL，以及 K3S_AGENT_TOKEN 或 K3S_TOKEN。
#
# 部署 Flux GitOps：flux-gitops.sh
#   前置条件：必须在 k3s 主节点运行，且 kubeconfig 存在并能读取。
#   必填：VPS_NODE_NAME、FLUX_GITHUB_OWNER
#   非必填：FLUX_GITHUB_REPO、FLUX_GITHUB_BRANCH、FLUX_GIT_SSH_KEY_FILE
#   条件必填：FLUX_GIT_AUTH=token 时填写 GITHUB_TOKEN 或 GH_TOKEN。
#
# 查看 k3s 节点 token：k3s-token.sh
#   前置条件：必须在 k3s 主节点运行。
#   无必填项；脚本会把 token 写回 K3S_AGENT_TOKEN。
#
# 配置 Cloudflare DNS：cloudflare-dns.sh
#   必填：CLOUDFLARE_API_TOKEN，或 CLOUDFLARE_EMAIL + CLOUDFLARE_API_KEY
#   写 Headscale 记录时需要：HEADSCALE_SERVER_URL
#   写 k3s 记录时需要：CLOUDFLARE_K3S_DNS_NAMES
#
# 部署 NodeGet hollow-net 探针页：nodeget-statusshow.sh
#   仅用于已接入 hollow-net 的 Alpine NAT LXC。
#   必填：NODEGET_STATUS_HOSTNAME、NODEGET_CLOUDFLARED_TOKEN
#   条件必填：页面显示实时 NodeGet 数据时填写 NODEGET_VISITOR_TOKEN
#   条件必填：脚本自动配置 Tunnel/DNS 时填写 NODEGET_DNS_CONFIG_TOKEN；
#     多 Account 或已知 Tunnel 时填写 NODEGET_CLOUDFLARE_ACCOUNT_ID、NODEGET_TUNNEL_ID。
#
# Headscale/k3s 主节点备份：vps-backup.sh headscale|k3s
#   必填：BACKUP_ENABLE=1
#   GPG 接收方必须有其一：BACKUP_GPG_EMAILS 或 BACKUP_GPG_RECIPIENTS
#   上传目标必须有其一：BACKUP_RCLONE_DESTS 或 BACKUP_GIT_REPOS
#
# 节点名。
VPS_NODE_NAME=

# 按场景填写的密钥。没有运行对应脚本时为空。
# BOOTSTRAP_AUTHORIZED_KEYS：新系统初始化时写入 root 和 BOOTSTRAP_USER 的 SSH 公钥。
#   为空时脚本读取 BOOTSTRAP_AUTHORIZED_KEYS_SOURCE，并合并 root、BOOTSTRAP_USER、
#   SUDO_USER、现有 UID>=1000 用户的 authorized_keys；forced-command key 不作为登录 key。
# HEADSCALE_AUTHKEY：Headscale preauth key；在 Headscale 主节点菜单里签发后复制过来。
# K3S_AGENT_TOKEN：k3s worker 加入集群用的 node-token；在 k3s 主节点菜单里查看。
# GITHUB_TOKEN：仅 FLUX_GIT_AUTH=token 或需要脚本自动创建/配置 GitHub 仓库时使用；
#   默认 SSH deploy key 流程不需要长期保存这个 token。
# CLOUDFLARE_API_TOKEN：自动写 DNS 记录时使用。权限范围为目标 Zone 的 DNS Edit。
BOOTSTRAP_AUTHORIZED_KEYS=
HEADSCALE_AUTHKEY=
K3S_AGENT_TOKEN=
GITHUB_TOKEN=
CLOUDFLARE_API_TOKEN=

# 全局偏好。
# VPS_PERSIST_ENV=1：首次运行后把当前配置安全复制到 /etc/hlwdot/vps.env；
#   后续 systemd 定时任务和子脚本会读取这个系统级配置。
# HOLLOW_NET_IFACE：tailscaled 创建的内网网卡名。k3s 默认也走这个网卡。
# HOLLOW_NET_UFW_ALLOW=1：如果系统有 ufw，就允许 hollow-net 网卡入站。
VPS_PERSIST_ENV=1
HOLLOW_NET_IFACE=hollow-net
HOLLOW_NET_UFW_ALLOW=1

# Debian 13 基础初始化。只支持 Debian 13，适合重装后的第一次系统整理。
# BOOTSTRAP_USER：日常登录用户，会加入 sudo。
# BOOTSTRAP_TIMEZONE / LOCALE：系统时区和默认 locale；EXTRA_LOCALES 会额外生成。
# BOOTSTRAP_SSH_PORT：sshd 监听端口；改动后脚本会同步 ufw 规则。
# BOOTSTRAP_SSH_LOCKDOWN=auto：只有成功写入 SSH 公钥后才禁用密码登录；1 强制禁用，0 保留。
# BOOTSTRAP_SUDO_NOPASSWD=auto：有公钥时启用免密 sudo；1/0 为强制开关。
# BOOTSTRAP_ENABLE_UFW / FAIL2BAN / UNATTENDED_UPGRADES / BBR：基础安全和网络优化开关。
# BOOTSTRAP_FULL_UPGRADE=1：初始化时执行 full-upgrade；业务机谨慎改动。
# BOOTSTRAP_AUTHORIZED_KEYS_SOURCE：没有直接填公钥时，从这个文件读取 SSH 公钥；
#   脚本还会合并 root、BOOTSTRAP_USER、SUDO_USER、现有 UID>=1000 用户的 authorized_keys；
#   forced-command key 不作为登录 key。
# BOOTSTRAP_USER_PASSWORD_HASH / BOOTSTRAP_USER_PASSWORD：密码登录条件下填写；密钥登录为空。
# BOOTSTRAP_SWAP_SIZE=auto：swapfile 所在文件系统可用空间小于或等于 1GB 时创建 128MB；
#   否则 MemTotal 小于或等于 2GB 时创建约等于 MemTotal 的 swapfile；
#   MemTotal 大于 2GB 时创建 4GB swapfile；有效值包括 0、1024M、2G、4G。
BOOTSTRAP_USER=hollow
BOOTSTRAP_TIMEZONE=Asia/Shanghai
BOOTSTRAP_LOCALE=en_US.UTF-8
BOOTSTRAP_EXTRA_LOCALES=zh_CN.UTF-8
BOOTSTRAP_SSH_PORT=22
BOOTSTRAP_SSH_LOCKDOWN=auto
BOOTSTRAP_SUDO_NOPASSWD=auto
BOOTSTRAP_ENABLE_UFW=1
BOOTSTRAP_ENABLE_FAIL2BAN=1
BOOTSTRAP_ENABLE_UNATTENDED_UPGRADES=1
BOOTSTRAP_FULL_UPGRADE=1
BOOTSTRAP_ENABLE_BBR=1
BOOTSTRAP_AUTHORIZED_KEYS_SOURCE=/root/.ssh/authorized_keys
BOOTSTRAP_USER_PASSWORD_HASH=
BOOTSTRAP_USER_PASSWORD=
BOOTSTRAP_ENABLE_SWAP=1
BOOTSTRAP_SWAPFILE=/swapfile
BOOTSTRAP_SWAP_SIZE=auto

# Alpine 基础初始化。只支持 Alpine Linux + OpenRC，适合初装后的第一次系统整理。
# 复用上方 BOOTSTRAP_* 变量：用户、SSH、公钥、安全开关、BBR。
# BOOTSTRAP_ENABLE_UFW=1 在 Alpine 下表示启用受管 iptables 防火墙。
# HOLLOW_NET_IFACE：Alpine bootstrap 防火墙默认放行这个内网网卡入站。
# BOOTSTRAP_ENABLE_UNATTENDED_UPGRADES=1 在 Alpine 下表示写入 daily apk upgrade 并启用 crond。
# ALPINE_LXC_MODE=1：按 Alpine LXC 执行；系统时钟和 swap 由宿主机/cgroup 管理，
#   脚本不在容器内安装/启动 chronyd，也不创建 swapfile/zram。
# ALPINE_LXC_MODE=auto：自动识别 LXC；识别到 LXC 时行为同上。
# ALPINE_LXC_MODE=0：按 Alpine VM/裸机执行；此时才使用 BOOTSTRAP_SWAPFILE / BOOTSTRAP_SWAP_SIZE 创建 swapfile。
#   非 LXC 环境里 swapfile 因底层文件系统含洞或不支持而无法启用时，脚本会改用 Alpine zram-init swap。
# ALPINE_ENABLE_COMMUNITY_REPO=1：缺包时启用 Alpine community 仓库。
# ALPINE_COMMUNITY_REPO_URL=auto：按当前 main 仓库推导 community；推导失败时按 Alpine 版本使用官方 CDN。
ALPINE_LXC_MODE=1
ALPINE_ENABLE_COMMUNITY_REPO=1
ALPINE_COMMUNITY_REPO_URL=auto

# Headscale 服务端。只在控制节点运行 headscale-server/headscale-main-node 时使用。
# HEADSCALE_SERVER_HOSTNAME：公开域名，例如 headscale.hlwdot.com。
# HEADSCALE_SERVER_URL：客户端访问地址；值为 auto 时脚本按 HOSTNAME/CLOUDFLARE_ZONE 推导。
# LISTEN/METRICS/GRPC 默认绑定 127.0.0.1，配合 Caddy 暴露 HTTPS，避免直接公网裸奔。
# HEADSCALE_DNS_BASE_DOMAIN：tailnet 内部 MagicDNS 域名，例如 net.hlwdot.com。
# HEADSCALE_USER：Headscale namespace/user 名称；签发 preauth key 时也会使用。
# HEADSCALE_CREATE_PREAUTHKEY=1：部署服务端后生成一个接入密钥；默认关闭。
# HEADSCALE_PREAUTH_REUSABLE=0：默认一次性接入密钥；1 表示同一 key 能重复使用。
# HEADSCALE_CONFIG_APPEND_FILE：需要追加自定义 Headscale YAML 片段时填写文件路径。
# HEADSCALE_ENABLE_CADDY=1：由 Caddy 反代并自动申请证书；auto 会按 URL 判断。
# HEADSCALE_CADDY_VERIFY=1：部署后检查 HTTPS /key 入口，防止拿到错误证书或反代错误。
# HEADSCALE_CADDY_REPAIR_CERT_CACHE=1：检测到 Caddy 证书缓存异常时尝试修复受管域名缓存。
# HEADSCALE_UFW_ALLOW=0：服务端本体默认不直接开公网端口；公网入口交给 Caddy。
# HEADSCALE_EXCLUSIVE_PUBLIC_PORTS=1：部署 Headscale+Caddy 时会避免和 k3s 公网入口抢 80/443。
HEADSCALE_VERSION=stable
HEADSCALE_SERVER_HOSTNAME=headscale.hlwdot.com
HEADSCALE_SERVER_URL=https://headscale.hlwdot.com
HEADSCALE_LISTEN_ADDR=127.0.0.1:8080
HEADSCALE_METRICS_LISTEN_ADDR=127.0.0.1:9090
HEADSCALE_GRPC_LISTEN_ADDR=127.0.0.1:50443
HEADSCALE_DNS_BASE_DOMAIN=net.hlwdot.com
HEADSCALE_USER=hollow
HEADSCALE_CREATE_PREAUTHKEY=0
HEADSCALE_PREAUTH_REUSABLE=0
HEADSCALE_PREAUTH_EXPIRATION=24h
HEADSCALE_CONFIG_APPEND_FILE=
HEADSCALE_UFW_ALLOW=0
HEADSCALE_UFW_PORTS=8080/tcp
HEADSCALE_ENABLE_CADDY=1
HEADSCALE_CADDYFILE=/etc/caddy/Caddyfile
HEADSCALE_CADDY_EMAIL=
HEADSCALE_CADDY_UFW_ALLOW=1
HEADSCALE_CADDY_VERIFY=1
HEADSCALE_CADDY_VERIFY_TIMEOUT_SEC=120
HEADSCALE_CADDY_REPAIR_CERT_CACHE=1
HEADSCALE_EXCLUSIVE_PUBLIC_PORTS=1
HEADSCALE_DISABLE_K3S_CONFLICTS=1

# Headscale 主节点组合部署。
# headscale-main-node 会部署服务端；HEADSCALE_MAIN_JOIN_SELF=1 时把本机也接入 hollow-net。
# 基础初始化由菜单里的“Debian 13 基础初始化”单独执行；本脚本不执行基础初始化。
HEADSCALE_MAIN_JOIN_SELF=1

# Headscale 客户端。所有需要加入 hollow-net 的 Debian 节点都会用到。
# HEADSCALE_CLIENT_IP：脚本接入成功后自动写入。
# HEADSCALE_ACCEPT_DNS=true：接受 Headscale 下发的 DNS；容器 DNS 冲突时填 false。
# HEADSCALE_ADVERTISE_ROUTES：要向 tailnet 广播的路由，逗号或空格分隔。
# HEADSCALE_ADVERTISE_EXIT_NODE=1：把当前节点作为 exit node 广播。
# HEADSCALE_ENABLE_TS_SSH=1：开启 Tailscale SSH；默认关闭，避免多一层远程入口。
# HEADSCALE_RESET=1：强制重写 tailscale up 参数，适合修改路由或 DNS 策略后重新应用。
# HEADSCALE_EXTRA_UP_ARGS：追加给 tailscale up 的原始参数；无追加参数时为空。
# HEADSCALE_ENDPOINT_CHECK=1：接入前先检查 /key 入口，能提前发现证书或反代问题。
HEADSCALE_CLIENT_IP=
HEADSCALE_ACCEPT_DNS=true
HEADSCALE_ADVERTISE_ROUTES=
HEADSCALE_ADVERTISE_EXIT_NODE=0
HEADSCALE_ENABLE_TS_SSH=0
HEADSCALE_RESET=0
HEADSCALE_EXTRA_UP_ARGS=
HEADSCALE_ENDPOINT_CHECK=1
HEADSCALE_ENDPOINT_CHECK_TIMEOUT_SEC=15
HEADSCALE_CLIENT_UP_TIMEOUT_SEC=120

# Alpine 节点 hollow-net 接入。
# 这类节点只接入内网或承担入站/出站分流，不部署 k3s。
# ALPINE_TAILSCALE_INSTALL_SOURCE=auto：优先满足最小版本；有效值包括 static、apk。
# ALPINE_TAILSCALE_STATIC_URL=auto：static 安装源自动按架构选择；也接受固定 tarball URL。
# ALPINE_ENABLE_FORWARDING=auto：需要分流/转发时自动开启内核转发。
# HOLLOW_OPENRC_SERVICE：OpenRC service 名，默认 hollow-tailscaled，避免覆盖系统 tailscaled。
# ALPINE_SPLIT_DIRECTION：none 不分流；outbound 让 tailnet 访问本机代理端口；
#   inbound 把公网端口转发到 tailnet 内部目标；both 同时启用。
# ALPINE_SPLIT_ROUTE_CIDRS：向 Headscale 广播的路由，例如 10.45.153.0/24。
# ALPINE_SPLIT_OUTBOUND_PROXY_PORTS：对 tailnet 开放的本机代理端口，例如 7890/tcp。
# ALPINE_SPLIT_INBOUND_FORWARDS：公网入站转发，格式 443/tcp=100.64.0.2:443。
# ALPINE_PUBLIC_IFACE=auto：自动探测公网网卡；入站分流识别失败时再手动指定。
# ALPINE_ALLOW_INTERACTIVE_LOGIN=0：默认不放开交互登录，避免低配 LXC 暴露过多入口。
# ALPINE_KILL_STALE_TAILSCALE_UP=1：清理卡住的 tailscale up，避免重复运行时被旧进程堵住。
ALPINE_TAILSCALE_INSTALL_SOURCE=auto
ALPINE_TAILSCALE_MIN_VERSION=1.74.0
ALPINE_TAILSCALE_STATIC_URL=auto
ALPINE_ENABLE_FORWARDING=auto
HOLLOW_OPENRC_SERVICE=hollow-tailscaled
ALPINE_SPLIT_DIRECTION=none
ALPINE_SPLIT_ROUTE_CIDRS=
ALPINE_SPLIT_OUTBOUND_PROXY_PORTS=
ALPINE_SPLIT_INBOUND_FORWARDS=
ALPINE_PUBLIC_IFACE=auto
ALPINE_ALLOW_INTERACTIVE_LOGIN=0
ALPINE_KILL_STALE_TAILSCALE_UP=1
ALPINE_TAILSCALE_UP_TIMEOUT_SEC=120

# NodeGet hollow-net 探针页。
# 仅用于 Alpine NAT LXC。NodeGet Server/Caddy 只监听 127.0.0.1，
# Agent 上报入口只绑定 hollow-net IPv4；对外访问只走 Cloudflare Tunnel，
# 不创建公网 A 记录直连 VPS。
# NODEGET_VISITOR_TOKEN 只供 server4.net 本机采集 NodeGet 数据；
# 不写入公网 config.json，使用完整 Visitor token：key:secret 或 username|password。
# NODEGET_CLOUDFLARED_TOKEN 使用 healthy-page Tunnel 运行 token。
# NODEGET_DNS_CONFIG_TOKEN 只在需要脚本配置 Tunnel public hostname / proxied CNAME 时填写；
# Cloudflare 权限限于对应 Account 的 Cloudflare Tunnel Edit 和对应 Zone 的 DNS Edit。
# DNS/隧道已配置好时，设置 NODEGET_TUNNEL_CONFIG_ENABLE=0 并省略 DNS token。
# NODEGET_STATUSSHOW_BUILD_MODE=prebuilt：使用本仓库 assets 里的预构建前端；build 表示现场构建。
# NODEGET_STATUS_HOSTNAME：公网访问域名，只通过 Cloudflare Tunnel 暴露。
# NODEGET_SERVER_LISTEN / STATUS_LISTEN 的值必须为 127.0.0.1 或 localhost，不能是 0.0.0.0。
# NODEGET_AGENT_LISTEN_ADDR=auto：自动绑定 hollow-net IPv4；Agent 上报入口不监听公网。
# NODEGET_TUNNEL_CONFIG_ENABLE=auto：有 DNS token 时自动配置 Tunnel；0 表示只运行已有 Tunnel。
# NODEGET_HOLLOW_DNS_SUFFIXES：从 Headscale 节点名里剥离的域名后缀，影响页面显示名。
# NODEGET_HOLLOW_NAME_ALIASES：显示名别名表，格式 old:NEW，逗号或空格分隔。
# NODEGET_HOLLOW_PUBLISH_IP=0：默认不把 hollow-net IP 写进公开数据，减少内网信息暴露。
NODEGET_VERSION=v0.1.4
NODEGET_RELEASE_REPO=GenshinMinecraft/NodeGet
NODEGET_STATUSSHOW_REPO=NodeSeekDev/NodeGet-StatusShow
NODEGET_STATUSSHOW_REF=276786c0853dbdbbdbfaf529d6b02dad501d689f
NODEGET_STATUSSHOW_VITE_VERSION=6.3.5
NODEGET_STATUSSHOW_REACT_PLUGIN_VERSION=4.7.0
NODEGET_STATUSSHOW_TYPES_NODE_VERSION=20.19.25
NODEGET_STATUSSHOW_MINIFY=0
NODEGET_STATUSSHOW_BUILD_MODE=prebuilt
NODEGET_STATUSSHOW_PREBUILT_ARCHIVE=
NODEGET_STATUS_HOSTNAME=nodeget.hlwdot.com
NODEGET_STATUS_SITE_NAME='Hollow Net Status'
NODEGET_STATUS_FOOTER='Powered by NodeGet'
NODEGET_STATUS_LOGO=
NODEGET_VISITOR_TOKEN=
NODEGET_SERVER_NAME=hollow-net
NODEGET_SERVER_UUID=auto_gen
NODEGET_SERVER_LISTEN=127.0.0.1:2211
NODEGET_STATUS_LISTEN=127.0.0.1:8221
NODEGET_DATABASE_URL='sqlite:///var/lib/nodeget-server/nodeget-server.db?mode=rwc'
NODEGET_JSONRPC_MAX_CONNECTIONS=80
NODEGET_AGENT_INGRESS_ENABLE=1
NODEGET_AGENT_LISTEN_ADDR=auto
NODEGET_AGENT_LISTEN_PORT=2211
NODEGET_CLOUDFLARED_ENABLE=1
NODEGET_CLOUDFLARED_VERSION=2026.3.0
NODEGET_CLOUDFLARED_TOKEN=
NODEGET_TUNNEL_CONFIG_ENABLE=auto
NODEGET_TUNNEL_NAME=healthy-page
NODEGET_TUNNEL_ID=
NODEGET_DNS_CONFIG_TOKEN=
NODEGET_CLOUDFLARE_ACCOUNT_ID=
NODEGET_CLOUDFLARE_ZONE=hlwdot.com
NODEGET_CLOUDFLARE_ZONE_ID=
NODEGET_HOLLOW_SYNC_INTERVAL_SEC=30
NODEGET_HOLLOW_DNS_SUFFIXES=net.hlwdot.com,hlwdot.com
NODEGET_HOLLOW_NAME_ALIASES=center:CNETER
NODEGET_HOLLOW_PUBLISH_IP=0

# k3s 主节点。运行 k3s-server 或 k3s-main-node 时使用。
# K3S_VERSION 留空表示使用官方安装脚本默认版本；需要固定版本时填 v1.xx.x+k3s1。
# K3S_TOKEN 留空时主节点脚本会生成或读取现有 token，并写回配置。
# K3S_NODE_IP / K3S_ADVERTISE_ADDRESS 留空时使用当前 hollow-net IPv4。
# K3S_FLANNEL_IFACE 默认 hollow-net，确保集群流量走 Headscale 内网。
# K3S_CLUSTER_CIDR / SERVICE_CIDR：Pod 和 Service 网段；已建集群不要随意改。
# K3S_DISABLE_COMPONENTS：传入 k3s 官方 disable 列表，例如 traefik,servicelb。
# K3S_KUBECONFIG_MODE=0600：默认 kubeconfig 只允许 root 读。
# K3S_ETCD_SNAPSHOT_*：主节点本地 etcd snapshot 定时、保留份数和压缩开关。
# K3S_SERVER_EXTRA_ARGS：追加给 k3s server 的参数；无追加参数时为空。
# K3S_UFW_ALLOW_ETCD=0：默认不放开 etcd 端口；多 server/HA 时才考虑开启。
# K3S_TAILNET_BOOT_WAIT_SEC：开机时等待 hollow-net 网卡就绪后再启动 k3s。
K3S_VERSION=
K3S_TOKEN=
K3S_CLUSTER_INIT=1
K3S_NODE_IP=
K3S_ADVERTISE_ADDRESS=
K3S_FLANNEL_IFACE=hollow-net
K3S_CLUSTER_CIDR=10.42.0.0/16
K3S_SERVICE_CIDR=10.43.0.0/16
K3S_DISABLE_COMPONENTS=
K3S_KUBECONFIG_MODE=0600
K3S_ETCD_SNAPSHOT_SCHEDULE='0 */12 * * *'
K3S_ETCD_SNAPSHOT_RETENTION=5
K3S_ETCD_SNAPSHOT_COMPRESS=1
K3S_SERVER_EXTRA_ARGS=
K3S_UFW_ALLOW=1
K3S_UFW_INTERFACE=hollow-net
K3S_UFW_ALLOW_ETCD=0
K3S_API_PORT=6443
K3S_TAILNET_BOOT_WAIT_SEC=120

# k3s 子节点。
# K3S_SERVER_URL：worker 连接主节点的 API 地址；值为主节点 hollow-net IP 或能访问的域名。
# K3S_SERVER_HOSTNAME 留空时不参与推导；填写后 agent 由它拼出 https://host:6443。
# K3S_AGENT_EXTRA_ARGS：追加给 k3s agent 的参数；无追加参数时为空。
# 默认接入当前中心节点 server999.center。更换中心节点时改 K3S_SERVER_URL。
K3S_SERVER_HOSTNAME=
K3S_SERVER_URL=https://100.64.0.2:6443
K3S_AGENT_EXTRA_ARGS=

# k3s 组合部署。
# k3s-main-node：检查 Headscale 已就绪，部署 k3s server，记录 worker token；K3S_MAIN_ENABLE_FLUX=1 时部署 Flux。
# k3s-worker-node：只部署 agent；不会自动初始化系统或接入 Headscale。
K3S_MAIN_ENABLE_FLUX=1

# Flux GitOps。只在 k3s 主节点上运行。
# 默认使用 SSH deploy key：脚本会生成 FLUX_GIT_SSH_KEY_FILE，并提示/尝试加入 GitHub deploy key。
# FLUX_GITHUB_OWNER / REPO / BRANCH 决定 GitOps 仓库位置。
# FLUX_GIT_AUTH=ssh：使用 SSH deploy key；FLUX_GIT_AUTH=token 时需要 GITHUB_TOKEN。
# FLUX_CLUSTER_NAME 留空时使用 VPS_NODE_NAME 作为集群名。
# FLUX_GITHUB_PATH 留空时生成 clusters/$FLUX_CLUSTER_NAME。
# FLUX_REPO_SCAFFOLD=1：仓库为空或缺少结构时写入基础目录和示例。
# FLUX_AGE_KEY_FILE：SOPS age 私钥保存位置；FLUX_AGE_PUBLIC_KEY 接受预填公钥。
# FLUX_INTERVAL / RETRY_INTERVAL / TIMEOUT：Flux 资源同步、失败重试和单次超时。
# FLUX_FORGET_GITHUB_TOKEN=1：成功后从配置文件移除 GITHUB_TOKEN，降低泄露风险。
FLUX_GITHUB_HOSTNAME=github.com
FLUX_GITHUB_OWNER=HollowDobt
FLUX_GITHUB_REPO=vps-gitops
FLUX_GITHUB_BRANCH=main
FLUX_GITHUB_PRIVATE=1
FLUX_GITHUB_PERSONAL=1
FLUX_GIT_AUTH=ssh
FLUX_GIT_URL=
FLUX_GIT_SSH_KEY_FILE=/etc/fluxcd/github-deploy.key
FLUX_CLUSTER_NAME=
FLUX_GITHUB_PATH=
FLUX_COMPONENTS_EXTRA=
FLUX_REPO_SCAFFOLD=1
FLUX_AGE_KEY_FILE=/etc/fluxcd/sops-age.agekey
FLUX_AGE_PUBLIC_KEY=
FLUX_INTERVAL=10m0s
FLUX_RETRY_INTERVAL=1m0s
FLUX_TIMEOUT=5m0s
FLUX_FORGET_GITHUB_TOKEN=1

# Cloudflare DNS。
# 优先使用 CLOUDFLARE_API_TOKEN；旧式全局 API Key 需要同时填 EMAIL + API_KEY。
# CLOUDFLARE_ZONE / ZONE_ID：脚本按域名自动找 zone；填 ZONE_ID 时跳过查找。
# CLOUDFLARE_DNS_TARGET_IPV4=auto：自动探测当前公网 IPv4。
# CLOUDFLARE_DNS_PROXIED=0：k3s/Ingress 记录是否开启 Cloudflare 代理；非 HTTP 服务不要开。
# CLOUDFLARE_DNS_TTL=120：DNS only 记录 TTL；开启代理时 Cloudflare 会自行处理。
# CLOUDFLARE_HEADSCALE_DNS=1：为 HEADSCALE_SERVER_URL 的主机名写 A 记录。
# Headscale 记录不要开启 Cloudflare 代理，所以脚本会强制用 DNS only 写 Headscale A 记录。
# CLOUDFLARE_K3S_DNS_TARGET=tailnet：k3s 相关 DNS 指向当前节点 hollow-net IP；
#   auto/public 指向公网 IP；也接受明确 IPv4。
# CLOUDFLARE_K3S_DNS_NAMES：要写给 k3s/Ingress 的域名，逗号或空格分隔。
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ZONE=hlwdot.com
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DNS_TARGET_IPV4=auto
CLOUDFLARE_DNS_PROXIED=0
CLOUDFLARE_DNS_TTL=120
CLOUDFLARE_HEADSCALE_DNS=1
CLOUDFLARE_K3S_DNS_TARGET=tailnet
CLOUDFLARE_K3S_DNS_NAMES=

# 主节点备份。默认关闭；只在 Headscale/k3s 主节点需要。
# BACKUP_ENABLE=1 后必须至少配置一个 GPG 接收方，以及一个上传目标。
# BACKUP_GPG_EMAILS：用 WKD/keyserver 查找公钥；BACKUP_GPG_RECIPIENTS：直接填指纹或 key id。
# BACKUP_GPG_PUBLIC_KEY_FILE/URL：需要导入固定公钥时使用。
# BACKUP_LOCAL_DIR：本地加密归档保存目录，明文临时目录会在退出时清理。
# BACKUP_RCLONE_DESTS：rclone 目标，逗号/空格分隔，例如 remote:hlwdot-backups。
# BACKUP_GIT_REPOS：git 备份仓库地址，脚本会提交加密归档和 sha256。
# BACKUP_KEEP_LOCAL：本地保留最近多少份加密归档。
# BACKUP_ON_CALENDAR / RANDOMIZED_DELAY_SEC：systemd timer 的运行时间和随机延迟。
BACKUP_ENABLE=0
BACKUP_GPG_EMAILS=
BACKUP_GPG_RECIPIENTS=
BACKUP_GPG_PUBLIC_KEY_FILE=
BACKUP_GPG_PUBLIC_KEY_URL=
BACKUP_LOCAL_DIR=/var/backups/hlwdot
BACKUP_KEEP_LOCAL=7
BACKUP_RCLONE_DESTS=
BACKUP_GIT_REPOS=
BACKUP_GIT_BRANCH=main
BACKUP_GIT_SUBDIR=vps-backups
BACKUP_ON_CALENDAR='*-*-* 03:30:00'
BACKUP_RANDOMIZED_DELAY_SEC=15m
