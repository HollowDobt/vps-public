# VPS 脚本配置示例。
#
# 使用方法：
#   cp scripts/.env.example scripts/.env
#   chmod 600 scripts/.env
#   vim scripts/.env
#
# 脚本会优先读取同目录 .env。首次部署时会按需复制到
# /etc/hlwdot/vps.env，供 systemd 定时备份任务读取。

VPS_PERSIST_ENV=1
HOLLOW_NET_IFACE=hollow-net

# Headscale 服务端。
# 如果前面有 Caddy、Nginx 或 Cloudflare Tunnel，建议 Headscale 只监听本机地址。
HEADSCALE_VERSION=stable
HEADSCALE_SERVER_URL=https://headscale.example.com
HEADSCALE_LISTEN_ADDR=127.0.0.1:8080
HEADSCALE_METRICS_LISTEN_ADDR=127.0.0.1:9090
HEADSCALE_GRPC_LISTEN_ADDR=127.0.0.1:50443
HEADSCALE_USER=hollow
HEADSCALE_CREATE_PREAUTHKEY=0
HEADSCALE_PREAUTH_REUSABLE=0
HEADSCALE_PREAUTH_EXPIRATION=24h
HEADSCALE_CONFIG_APPEND_FILE=
HEADSCALE_UFW_ALLOW=0
HEADSCALE_UFW_PORTS=8080/tcp

# 接入 Headscale 的客户端。
# HEADSCALE_AUTHKEY 留空时，tailscale up 会输出登录 URL，由你手动完成注册。
HEADSCALE_AUTHKEY=
HEADSCALE_CLIENT_HOSTNAME=
HEADSCALE_ACCEPT_DNS=true
HEADSCALE_ADVERTISE_ROUTES=
HEADSCALE_ADVERTISE_EXIT_NODE=0
HEADSCALE_ENABLE_TS_SSH=0
HEADSCALE_RESET=0
HEADSCALE_EXTRA_UP_ARGS=

# k3s 主节点。
# K3S_TOKEN 留空时主节点脚本会生成一个 token，并写入 /etc/rancher/k3s/config.yaml。
K3S_VERSION=
K3S_TOKEN=
K3S_CLUSTER_INIT=1
K3S_NODE_NAME=
K3S_NODE_IP=
K3S_ADVERTISE_ADDRESS=
K3S_FLANNEL_IFACE=hollow-net
K3S_CLUSTER_CIDR=10.42.0.0/16
K3S_SERVICE_CIDR=10.43.0.0/16
K3S_DISABLE_COMPONENTS=
K3S_KUBECONFIG_MODE=0600
K3S_ETCD_SNAPSHOT_SCHEDULE='0 */12 * * *'
K3S_ETCD_SNAPSHOT_RETENTION=5
K3S_ETCD_SNAPSHOT_COMPRESS=1
K3S_SERVER_EXTRA_ARGS=
K3S_UFW_ALLOW=1
K3S_UFW_INTERFACE=hollow-net
K3S_API_PORT=6443

# k3s 子节点。
K3S_SERVER_HOSTNAME=
K3S_SERVER_URL=
K3S_AGENT_EXTRA_ARGS=

# Cloudflare DNS。
# 推荐使用 API Token；如果只方便使用全局 API Key，则同时填写邮箱和 Key。
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ZONE=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DNS_TARGET_IPV4=auto
CLOUDFLARE_DNS_PROXIED=0
CLOUDFLARE_DNS_TTL=120
CLOUDFLARE_HEADSCALE_DNS=1
CLOUDFLARE_K3S_DNS_TARGET=tailnet
CLOUDFLARE_K3S_DNS_NAMES=

# 主节点备份。
# BACKUP_GPG_EMAILS 会通过 WKD/keyserver 查找公钥；也可以直接填 fingerprint。
# rclone 目标使用 rclone remote:path；git 目标使用 SSH/HTTPS 仓库地址。
BACKUP_ENABLE=0
BACKUP_GPG_EMAILS=
BACKUP_GPG_RECIPIENTS=
BACKUP_GPG_PUBLIC_KEY_FILE=
BACKUP_GPG_PUBLIC_KEY_URL=
BACKUP_LOCAL_DIR=/var/backups/hlwdot
BACKUP_KEEP_LOCAL=7
BACKUP_RCLONE_DESTS=
BACKUP_GIT_REPOS=
BACKUP_GIT_BRANCH=main
BACKUP_GIT_SUBDIR=vps-backups
BACKUP_ON_CALENDAR='*-*-* 03:30:00'
BACKUP_RANDOMIZED_DELAY_SEC=15m
